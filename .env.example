# ==============================================================================
# MERN Review & Rating Platform - Environment Configuration Variables
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Express Backend Server Environment (apps/api)
# ------------------------------------------------------------------------------
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/review-rating-db

# Cloudinary Integration API Credentials (For Company Logo Uploads)
# Note: If these credentials are left empty/unconfigured, the backend will 
# automatically fallback to local file storage under `/public/uploads` directory.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT Secret (Ready for authorization structures)
JWT_SECRET=review_sphere_super_secret_jwt_sign_key_12345

# ------------------------------------------------------------------------------
# 2. Next.js Frontend App Environment (apps/web)
# ------------------------------------------------------------------------------
# API server address (Express REST service root endpoint)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
